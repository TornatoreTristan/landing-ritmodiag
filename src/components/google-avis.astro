---
import { Image } from 'astro:assets'
import logoGoogle from '../assets/img/google-avis-ritmodiag.svg'
---

<div class="mt-6 inline-flex self-start gap-4 items-center p-3 border border-gray-200 rounded-2xl text-sm bg-white">
  <div class="shrink-0">
    <Image src={logoGoogle} alt="" width={40} height={40} />
  </div>
  <div>
    <p class="font-semibold">+267 avis Google</p>
    <div class="flex items-center gap-1.5">
      <div class="flex" aria-label="4.9 étoiles sur 5" role="img">
        {Array.from({ length: 5 }).map((_, i) => (
          <svg class="size-3.5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
      <span class="font-semibold text-gray-600">4,9/5</span>
    </div>
  </div>
</div>
